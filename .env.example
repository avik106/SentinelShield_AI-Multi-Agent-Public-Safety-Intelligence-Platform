# ==============================================================================
# SentinelShield AI — Configuration Template (.env.example)
# ==============================================================================
# Copy this file to '.env' in the project root and fill in your custom values.
# The application runs with safe in-memory/mock defaults if variables are omitted.

# ------------------------------------------------------------------------------
# 1. CORE API SETTINGS
# ------------------------------------------------------------------------------
DEBUG=false
SECRET_KEY=generate-a-secure-secret-key-for-session-tokens
CORS_ORIGINS=["http://localhost:5173", "http://127.0.0.1:5173"]

# ------------------------------------------------------------------------------
# 2. DATABASE CONNECTORS (OPTIONAL - FALLS BACK TO IN-MEMORY & LOCAL CACHES)
# ------------------------------------------------------------------------------
# PostgreSQL Database (Historical case ingestion for Geospatial Hotspots)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=sentinelshield
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_secure_password

# Redis Cache (Fast token caching and rate limiting)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Neo4j Graph DB (Linked entity network community clustering)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_secure_password

# Qdrant Vector DB (Legal statute and case law embeddings retrieval)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# MinIO Object Storage (Persisting report PDFs and voice uploads)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ------------------------------------------------------------------------------
# 3. AI / COGNITIVE AGENT MODELS
# ------------------------------------------------------------------------------
# LLM Orchestrator Provider: huggingface | groq | openai | gemini | local
LLM_PROVIDER=huggingface
LLM_MODEL_NAME=mistralai/Mistral-7B-Instruct-v0.3

# Provider Credentials (Only required for the active LLM_PROVIDER)
HUGGINGFACEHUB_API_TOKEN=your_huggingface_write_token
GROQ_API_KEY=gsk_your_groq_api_key
OPENAI_API_KEY=sk-proj-your_openai_api_key
GEMINI_API_KEY=AIzaSy_your_gemini_api_key

# RAG Knowledge Embeddings Model
EMBEDDING_MODEL=BAAI/bge-m3

# Voice Agent - Speech transcription & synthetic voice audit
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu

# Counterfeit Currency Agent - Rupee banknote check weights
YOLO_MODEL_PATH=shared/weights/yolo_currency.pt
YOLO_CONFIDENCE=0.60

# Scam Detection Agent - Intent classifier model
SCAM_CLASSIFIER_MODEL=joeddav/xlm-roberta-large-xnli
SCAM_RISK_THRESHOLD=0.55

# RAG Investigation Copilot parameters
RAG_MIN_CONFIDENCE=0.20
RAG_TOP_K=5
RAG_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
